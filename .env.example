# Variables para levantar todo el stack con "docker-compose up".
# Copiar a .env (no se commitea) y completar los valores reales.

# Postgres local (contenedor "db")
DB_NAME=lucma_dev
DB_USER=postgres
DB_PASSWORD=postgres123

# Backend
SECRET_KEY=dev-secret-key-cambiar
JWT_SECRET_KEY=dev-jwt-secret-key-cambiar
FLASK_ENV=development

# Google Maps / Calendar (opcional, pendiente de credenciales reales)
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# SMTP (opcional, pendiente de credenciales reales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_COLABORADORES=

# Cloudinary (opcional, para reemplazar almacenamiento local de imagenes)
CLOUDINARY_URL=

# Frontend (dejar vacio para que use el proxy /api de nginx hacia el backend)
VITE_API_URL=
