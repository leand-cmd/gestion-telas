# Base de datos (Railway PostgreSQL connection string)
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# Seguridad
SECRET_KEY=cambiar-por-una-clave-secreta-larga
JWT_SECRET_KEY=cambiar-por-otra-clave-secreta-larga

# Entorno
FLASK_ENV=development
FLASK_DEBUG=1
CORS_ORIGINS=http://localhost:5173

# Google Maps / Calendar (pendiente de credenciales reales)
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# SMTP (pendiente de credenciales reales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Emails de companeros que reciben copia de los pedidos enviados (separados por coma)
EMAIL_COLABORADORES=

# Cloudinary (imagenes de productos). Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
